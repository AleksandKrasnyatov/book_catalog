<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Yii2 Project">
    <description>PHP CodeSniffer configuration for Yii2 project</description>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/smspilot/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/config/*</exclude-pattern>
    <exclude-pattern>*/views/*</exclude-pattern>
    <exclude-pattern>*/runtime/*</exclude-pattern>
    <exclude-pattern>*/web/*</exclude-pattern>
    <exclude-pattern>*/migrations/*</exclude-pattern>
    <exclude-pattern>*.js</exclude-pattern>
    <exclude-pattern>*.css</exclude-pattern>

    <rule ref="PSR12"/>
    <rule ref="PSR2.Classes.PropertyDeclaration.Underscore">
        <exclude-pattern>*/models/*</exclude-pattern>
    </rule>
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>
    <rule ref="Generic.CodeAnalysis.EmptyStatement"/>
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="180"/>
        </properties>
    </rule>

    <rule ref="PSR12.Properties.ConstantVisibility.NotFound">
        <exclude-pattern>*/models/*</exclude-pattern>
    </rule>

    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

<!--    <arg name="cache" value=".phpcs-cache"/>-->
</ruleset>
